// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  player        Player?
  clubs         Club[]
  entries       Entry[] // entries created by this user
  entryPlayers  EntryPlayer[] // entries this user participates in

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Player {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  nickname    String?

  dominantHand  String? // RIGHT | LEFT | BOTH
  preferredSide String? // LEFT | RIGHT | BOTH
  playStyle     String? // AGGRESSIVE | DEFENSIVE | BALANCED
  level         String? // BEGINNER | INTERMEDIATE | ADVANCED | PRO

  heightCm  Int?
  birthDate DateTime?

  about String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("player")
}

model Club {
  id          String @id @default(cuid())
  ownerUserId String
  owner       User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  name        String
  description String?
  address     String?
  city        String?
  state       String?
  country     String?
  phone       String?
  website     String?
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]
  courts      Court[]

  @@index([ownerUserId])
  @@map("club")
}

model Tournament {
  id     String  @id @default(cuid())
  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id], onDelete: SetNull)

  name        String
  description String?
  venueNote   String?
  location    String?
  imageUrl    String?

  startDate DateTime
  endDate   DateTime?

  status     String @default("DRAFT") // DRAFT | REGISTRATION_OPEN | REGISTRATION_CLOSED | IN_PROGRESS | FINISHED | CANCELLED
  visibility String @default("PUBLIC") // PUBLIC | PRIVATE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories TournamentCategory[]

  @@index([clubId])
  @@map("tournament")
}

model TournamentCategory {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  name          String
  modality      String? // SINGLES | DOUBLES
  gender        String? // MALE | FEMALE | MIXED | OPEN
  level         String?
  entryFeeCents Int?
  maxEntries    Int?
  rules         String?

  createdAt DateTime @default(now())

  entries Entry[]
  stages  Stage[]

  @@unique([tournamentId, name])
  @@index([tournamentId])
  @@map("tournament_category")
}

// =========================
// ENTRIES / PLAYERS
// =========================

model Entry {
  id              String             @id @default(cuid())
  categoryId      String
  category        TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User               @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  status     String  @default("PENDING") // PENDING | CONFIRMED | WAITLIST | CANCELLED
  publicName String?
  seed       Int?

  createdAt DateTime @default(now())

  players      EntryPlayer[]
  payments     Payment[]
  groupMembers GroupMember[]
  matchesAsA   Match[]       @relation("MatchEntryA")
  matchesAsB   Match[]       @relation("MatchEntryB")
  matchesWon   Match[]       @relation("MatchWinner")

  @@index([categoryId])
  @@index([createdByUserId])
  @@map("entry")
}

model EntryPlayer {
  id       String @id @default(cuid())
  entryId  String
  entry    Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  position Int // 1 or 2 (doubles)

  createdAt DateTime @default(now())

  @@unique([entryId, userId])
  @@unique([entryId, position])
  @@index([userId])
  @@map("entry_player")
}

model Payment {
  id          String    @id @default(cuid())
  entryId     String
  entry       Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  provider    String?
  providerRef String?
  amountCents Int?
  currency    String?
  status      String    @default("INITIATED") // INITIATED | PAID | FAILED | REFUNDED
  paidAt      DateTime?

  createdAt DateTime @default(now())

  @@index([entryId])
  @@map("payment")
}

// =========================
// STAGES / GROUPS / COURTS / MATCHES
// =========================

model Stage {
  id         String             @id @default(cuid())
  categoryId String
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name      String
  stageType String // GROUPS | SINGLE_ELIMINATION | ROUND_ROBIN
  sortOrder Int?
  status    String @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED

  createdAt DateTime @default(now())

  groups  Group[]
  matches Match[]

  @@index([categoryId])
  @@map("stage")
}

model Group {
  id      String @id @default(cuid())
  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())

  members GroupMember[]
  matches Match[]

  @@unique([stageId, name])
  @@index([stageId])
  @@map("group")
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entryId String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, entryId])
  @@index([groupId])
  @@index([entryId])
  @@map("group_member")
}

model Court {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  matches Match[]

  @@index([clubId])
  @@map("court")
}

model Match {
  id      String  @id @default(cuid())
  stageId String
  stage   Stage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  roundLabel String?
  matchOrder Int?

  entryAId String
  entryA   Entry  @relation("MatchEntryA", fields: [entryAId], references: [id], onDelete: Cascade)
  entryBId String
  entryB   Entry  @relation("MatchEntryB", fields: [entryBId], references: [id], onDelete: Cascade)

  scheduledAt DateTime?
  courtId     String?
  court       Court?    @relation(fields: [courtId], references: [id], onDelete: SetNull)

  status        String  @default("SCHEDULED") // SCHEDULED | LIVE | COMPLETED | WALKOVER | CANCELLED
  winnerEntryId String?
  winner        Entry?  @relation("MatchWinner", fields: [winnerEntryId], references: [id], onDelete: SetNull)
  notes         String?

  createdAt DateTime @default(now())

  sets MatchSet[]

  @@index([stageId])
  @@index([groupId])
  @@index([entryAId])
  @@index([entryBId])
  @@index([courtId])
  @@map("match")
}

model MatchSet {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  setNumber   Int
  entryAGames Int
  entryBGames Int
  tiebreakA   Int?
  tiebreakB   Int?

  @@unique([matchId, setNumber])
  @@index([matchId])
  @@map("match_set")
}
