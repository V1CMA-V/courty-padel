---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import { TournamentForm } from '@/components/TournamentForm'
export const prerender = false
---

<DashboardLayout title="Nuevo Torneo - Courty Padel">
  <div class="space-y-6 max-w-4xl">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Crear nuevo torneo</h1>
      <p class="text-muted-foreground">Llena los datos de tu torneo y agrega las categorías.</p>
    </div>

    <TournamentForm client:load />
  </div>
</DashboardLayout>
