---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
export const prerender = false
---

<DashboardLayout title="Pistas - Courty Padel">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Pistas</h1>
      <p class="text-muted-foreground">Administra las pistas de tu club.</p>
    </div>

    <div class="flex items-center justify-center rounded-xl border border-dashed bg-card p-16">
      <div class="text-center">
        <p class="text-lg font-medium text-muted-foreground">No tienes pistas registradas</p>
        <p class="mt-1 text-sm text-muted-foreground">Agrega tus pistas para gestionar reservas.</p>
      </div>
    </div>
  </div>
</DashboardLayout>
