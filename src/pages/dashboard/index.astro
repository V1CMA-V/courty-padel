---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
export const prerender = false
---

<DashboardLayout title="Inicio - Courty Padel">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">
        Bienvenido a Courty Padel
      </h1>
      <p class="text-muted-foreground">Aquí tienes un resumen de tu club.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm font-medium text-muted-foreground">Torneos Activos</p>
        <p class="mt-1 text-3xl font-bold">0</p>
      </div>
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm font-medium text-muted-foreground">Pistas</p>
        <p class="mt-1 text-3xl font-bold">0</p>
      </div>
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm font-medium text-muted-foreground">Jugadores</p>
        <p class="mt-1 text-3xl font-bold">0</p>
      </div>
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm font-medium text-muted-foreground">Mi Club</p>
        <p class="mt-1 text-3xl font-bold">—</p>
      </div>
    </div>
  </div>
</DashboardLayout>
