---
export const prerender = false

import { PlayerProfileForm } from '@/components/PlayerProfileForm'
import UserSidebar from '@/components/UserSidebar.astro'
import Layout from '@/layouts/Layout.astro'
import { auth } from '@/lib/auth'

const session = await auth.api.getSession({
  headers: Astro.request.headers,
})

if (!session?.user?.id) return Astro.redirect('/sign-in')

const user = {
  name: session.user.name,
  email: session.user.email,
  image: session.user.image,
}

const currentPath = Astro.url.pathname
---

<Layout title="Mi Cuenta - Courty Padel">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-foreground">Configuración</h1>
      <p class="text-sm text-muted-foreground mt-1">
        Administra tu cuenta y perfil de jugador.
      </p>
    </div>
    <div class="flex flex-col md:flex-row gap-8">
      <UserSidebar currentPath={currentPath} />
      <div class="flex-1 min-w-0">
        <PlayerProfileForm client:load user={user} />
      </div>
    </div>
  </div>
</Layout>
